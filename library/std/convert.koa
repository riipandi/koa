/// Convert boolean to string
pub fn bool_to_string(b: bool): string {
    if b {
        return "true";
    }
    return "false";
}

/// Convert string to boolean
pub fn string_to_bool(s: string): bool {
    if s == "true" {
        return true;
    }
    return false;
}
