/// Minimum of two values
pub fn min(x: f64, y: f64): f64 {
    if x < y {
        return x;
    }
    return y;
}

/// Maximum of two values
pub fn max(x: f64, y: f64): f64 {
    if x > y {
        return x;
    }
    return y;
}

